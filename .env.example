# Copy this file to .env.local for local development.
# In Vercel, add the same NEXT_PUBLIC_* variables under Project Settings → Environment Variables.

# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed locally to run `npm run seed` — never expose this to the browser
# or commit a real value. It bypasses Row Level Security.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
